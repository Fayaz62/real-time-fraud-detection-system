def run_demo():
    logger.info("\n" + "=" * 60)
    logger.info("  Real-Time Fraud Detection System — Demo")
    logger.info("  Author: Shaik Fayaz Ahammaed")
    logger.info("=" * 60 + "\n")

    # Step 1: Train if models don't exist yet
    if not os.path.exists(RF_MODEL_PATH):
        df = generate_transaction_data(n_samples=10000, fraud_ratio=0.02)
        train_models(df)
    else:
        logger.info("Pre-trained models found — skipping training.")

    # Step 2: Load real-time detector
    detector = FraudDetector()

    # Step 3: Sample transactions
    sample_transactions = [
        {   # Normal daytime purchase
            "transaction_id"    : "TXN-001",
            "transaction_amount": 1200.0,
            "transaction_hour"  : 14,
            "day_of_week"       : 2,
            "merchant_category" : 3,
            "user_age"          : 850,
            "distance_from_home": 5.2,
            "transaction_freq"  : 1.8,
            "failed_attempts"   : 0,
            "is_international"  : 0,
        },
        {   # Suspicious: large, late night, new account, far from home
            "transaction_id"    : "TXN-002",
            "transaction_amount": 85000.0,
            "transaction_hour"  : 3,
            "day_of_week"       : 6,
            "merchant_category" : 7,
            "user_age"          : 4,
            "distance_from_home": 1200.0,
            "transaction_freq"  : 35.0,
            "failed_attempts"   : 4,
            "is_international"  : 1,
        },
        {   # Medium-risk: international, some failed attempts
            "transaction_id"    : "TXN-003",
            "transaction_amount": 15000.0,
            "transaction_hour"  : 22,
            "day_of_week"       : 5,
            "merchant_category" : 2,
            "user_age"          : 120,
            "distance_from_home": 300.0,
            "transaction_freq"  : 8.0,
            "failed_attempts"   : 2,
            "is_international"  : 1,
        },
    ]

    # Step 4: Batch predict & show results
    logger.info("\n--- Processing Sample Transactions ---")
    results = detector.batch_predict(sample_transactions)
    print("\n" + results[
        ["transaction_id", "amount", "risk_level", "combined_score", "alert"]
    ].to_string(index=False))

    # Step 5: Risk timeline chart
    plot_transaction_timeline(results)

    # Step 6: Alert summary
    summary = detector.get_alert_summary()
    logger.info(f"\nAlert Summary: {summary}")


if __name__ == "__main__":
    run_demo()



def plot_class_distribution(y: pd.Series, save: bool = True) -> str:
    """Bar + pie chart of fraud vs legitimate class balance."""
    counts = y.value_counts()
    labels = ["Legitimate", "Fraudulent"]
    colors = [PALETTE["legit"], PALETTE["fraud"]]

    fig, axes = plt.subplots(1, 2, figsize=(10, 4))

    axes[0].bar(labels, counts.values, color=colors, width=0.5, edgecolor="white", linewidth=1.5)
    axes[0].set_title("Transaction Class Distribution", fontweight="bold")
    axes[0].set_ylabel("Count")
    for i, v in enumerate(counts.values):
        axes[0].text(i, v + 20, f"{v:,}", ha="center", fontsize=10, fontweight="bold")

    axes[1].pie(counts.values, labels=labels, colors=colors, autopct="%1.2f%%",
                startangle=90, wedgeprops=dict(edgecolor="white", linewidth=2))
    axes[1].set_title("Fraud vs Legitimate (%)", fontweight="bold")

    plt.tight_layout()
    path = os.path.join(OUTPUT_DIR, "class_distribution.png")
    if save:
        plt.savefig(path, dpi=150, bbox_inches="tight")
        print(f"Saved: {path}")
    plt.close()
    return path


def plot_feature_distributions(df: pd.DataFrame, save: bool = True) -> str:
    """Overlapping histograms per feature, coloured by fraud label."""
    features = [
        "transaction_amount", "transaction_hour",
        "distance_from_home", "transaction_freq",
        "failed_attempts", "user_age"
    ]
    fig, axes = plt.subplots(2, 3, figsize=(15, 8))
    axes = axes.flatten()

    for i, feat in enumerate(features):
        for label, color, name in [
            (0, PALETTE["legit"], "Legitimate"),
            (1, PALETTE["fraud"], "Fraudulent")
        ]:
            axes[i].hist(df[df["is_fraud"] == label][feat],
                         bins=40, alpha=0.6, color=color, label=name, density=True)
        axes[i].set_title(feat.replace("_", " ").title(), fontweight="bold")
        axes[i].legend(fontsize=8)

    plt.suptitle("Feature Distributions: Fraudulent vs Legitimate",
                 fontsize=14, fontweight="bold", y=1.01)
    plt.tight_layout()
    path = os.path.join(OUTPUT_DIR, "feature_distributions.png")
    if save:
        plt.savefig(path, dpi=150, bbox_inches="tight")
        print(f"Saved: {path}")
    plt.close()
    return path


def plot_confusion_matrix(y_true, y_pred, save: bool = True) -> str:
    """Heatmap of TP / FP / TN / FN."""
    cm = confusion_matrix(y_true, y_pred)
    fig, ax = plt.subplots(figsize=(6, 5))
    sns.heatmap(cm, annot=True, fmt="d", cmap="YlOrRd",
                xticklabels=["Predicted Legit", "Predicted Fraud"],
                yticklabels=["Actual Legit",    "Actual Fraud"],
                linewidths=1, linecolor="white", ax=ax)
    ax.set_title("Confusion Matrix", fontweight="bold", fontsize=13)
    plt.tight_layout()
    path = os.path.join(OUTPUT_DIR, "confusion_matrix.png")
    if save:
        plt.savefig(path, dpi=150, bbox_inches="tight")
        print(f"Saved: {path}")
    plt.close()
    return path


def plot_roc_curve(y_true, y_prob, save: bool = True) -> str:
    """ROC curve with AUC annotation."""
    fpr, tpr, _ = roc_curve(y_true, y_prob)
    roc_auc     = auc(fpr, tpr)

    fig, ax = plt.subplots(figsize=(6, 5))
    ax.plot(fpr, tpr, color=PALETTE["fraud"], lw=2,
            label=f"ROC Curve (AUC = {roc_auc:.4f})")
    ax.plot([0, 1], [0, 1], color="gray", lw=1, linestyle="--", label="Random Classifier")
    ax.fill_between(fpr, tpr, alpha=0.1, color=PALETTE["fraud"])
    ax.set_xlabel("False Positive Rate")
    ax.set_ylabel("True Positive Rate")
    ax.set_title("ROC Curve — Fraud Detection Model", fontweight="bold")
    ax.legend(loc="lower right")
    plt.tight_layout()
    path = os.path.join(OUTPUT_DIR, "roc_curve.png")
    if save:
        plt.savefig(path, dpi=150, bbox_inches="tight")
        print(f"Saved: {path}")
    plt.close()
    return path


def plot_feature_importance(model, feature_names: list, save: bool = True) -> str:
    """Horizontal bar chart of Random Forest feature importances."""
    importances = pd.Series(model.feature_importances_, index=feature_names).sort_values()
    colors = [PALETTE["fraud"] if v > importances.median() else PALETTE["neutral"]
              for v in importances]

    fig, ax = plt.subplots(figsize=(8, 6))
    importances.plot(kind="barh", ax=ax, color=colors, edgecolor="white", linewidth=0.8)
    ax.set_title("Feature Importance — Random Forest", fontweight="bold")
    ax.set_xlabel("Importance Score")
    for bar in ax.patches:
        ax.text(bar.get_width() + 0.002, bar.get_y() + bar.get_height() / 2,
                f"{bar.get_width():.3f}", va="center", fontsize=9)
    plt.tight_layout()
    path = os.path.join(OUTPUT_DIR, "feature_importance.png")
    if save:
        plt.savefig(path, dpi=150, bbox_inches="tight")
        print(f"Saved: {path}")
    plt.close()
    return path


def plot_transaction_timeline(results_df: pd.DataFrame, save: bool = True) -> str:
    """Bar chart of combined risk scores for a batch of transactions."""
    color_map = {
        "LOW"     : PALETTE["legit"],
        "MEDIUM"  : PALETTE["warn"],
        "HIGH"    : PALETTE["fraud"],
        "CRITICAL": "#8B0000",
    }
    fig, ax = plt.subplots(figsize=(12, 4))
    x      = range(len(results_df))
    colors = [color_map.get(r, PALETTE["neutral"]) for r in results_df["risk_level"]]

    ax.bar(x, results_df["combined_score"], color=colors, edgecolor="white", linewidth=0.8)
    ax.axhline(0.60, color="red", linestyle="--", linewidth=1, label="Alert Threshold (0.60)")
    ax.set_xticks(list(x))
    ax.set_xticklabels(results_df["transaction_id"].tolist(), rotation=30, ha="right", fontsize=9)
    ax.set_ylabel("Combined Risk Score")
    ax.set_title("Transaction Risk Timeline", fontweight="bold")

    patches = [mpatches.Patch(color=v, label=k) for k, v in color_map.items()]
    ax.legend(
        handles=patches + [plt.Line2D([0], [0], color="red", linestyle="--", label="Threshold")],
        loc="upper right", fontsize=8
    )
    plt.tight_layout()
    path = os.path.join(OUTPUT_DIR, "transaction_timeline.png")
    if save:
        plt.savefig(path, dpi=150, bbox_inches="tight")
        print(f"Saved: {path}")
    plt.close()
    return path



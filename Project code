# ══════════════════════════════════════════════════════════════
# SECTION 1 — DATA GENERATION
# ══════════════════════════════════════════════════════════════

def generate_transaction_data(n_samples: int = 10000, fraud_ratio: float = 0.02) -> pd.DataFrame:
    """
    Simulate a labelled transaction dataset.

    Features
    --------
    transaction_amount  : float  — Amount in INR
    transaction_hour    : int    — Hour of day (0-23)
    day_of_week         : int    — 0=Mon ... 6=Sun
    merchant_category   : int    — Encoded category (0-9)
    user_age            : int    — Account age in days
    distance_from_home  : float  — km from registered address
    transaction_freq    : float  — Transactions per day (7-day avg)
    failed_attempts     : int    — Recent failed login attempts
    is_international    : int    — 1 = international, 0 = domestic
    is_fraud            : int    — Ground-truth label
    """
    np.random.seed(42)
    n_fraud = int(n_samples * fraud_ratio)
    n_legit = n_samples - n_fraud

    # Legitimate transactions
    legit = pd.DataFrame({
        "transaction_amount": np.random.lognormal(mean=7, sigma=1.2, size=n_legit),
        "transaction_hour"  : np.random.choice(range(8, 22), size=n_legit),
        "day_of_week"       : np.random.randint(0, 7, size=n_legit),
        "merchant_category" : np.random.randint(0, 10, size=n_legit),
        "user_age"          : np.random.randint(30, 2000, size=n_legit),
        "distance_from_home": np.abs(np.random.normal(10, 15, size=n_legit)),
        "transaction_freq"  : np.random.uniform(0.5, 5, size=n_legit),
        "failed_attempts"   : np.random.choice([0, 1], size=n_legit, p=[0.95, 0.05]),
        "is_international"  : np.random.choice([0, 1], size=n_legit, p=[0.85, 0.15]),
        "is_fraud"          : 0,
    })

    # Fraudulent transactions (anomalous patterns)
    fraud = pd.DataFrame({
        "transaction_amount": np.random.lognormal(mean=9, sigma=1.5, size=n_fraud),
        "transaction_hour"  : np.random.choice(range(0, 6), size=n_fraud),    # late night
        "day_of_week"       : np.random.randint(0, 7, size=n_fraud),
        "merchant_category" : np.random.randint(0, 10, size=n_fraud),
        "user_age"          : np.random.randint(1, 30, size=n_fraud),         # new accounts
        "distance_from_home": np.abs(np.random.normal(500, 300, size=n_fraud)),
        "transaction_freq"  : np.random.uniform(10, 50, size=n_fraud),        # high frequency
        "failed_attempts"   : np.random.choice([2, 3, 4, 5], size=n_fraud),   # many failures
        "is_international"  : np.random.choice([0, 1], size=n_fraud, p=[0.3, 0.7]),
        "is_fraud"          : 1,
    })

    df = pd.concat([legit, fraud], ignore_index=True).sample(frac=1, random_state=42)
    logger.info(f"Dataset generated: {len(df)} transactions ({n_fraud} fraudulent = {fraud_ratio*100:.1f}%)")
    return df


# ══════════════════════════════════════════════════════════════
# SECTION 2 — FEATURE ENGINEERING
# ══════════════════════════════════════════════════════════════

FEATURE_COLS = [
    "transaction_amount", "transaction_hour", "day_of_week",
    "merchant_category", "user_age", "distance_from_home",
    "transaction_freq", "failed_attempts", "is_international"
]

ENGINEERED_COLS = FEATURE_COLS + ["amount_log", "is_night", "high_freq_flag", "risk_score"]


def engineer_features(df: pd.DataFrame) -> pd.DataFrame:
    """Add derived features to improve model accuracy."""
    df = df.copy()
    df["amount_log"]     = np.log1p(df["transaction_amount"])
    df["is_night"]       = df["transaction_hour"].apply(lambda h: 1 if h < 6 else 0)
    df["high_freq_flag"] = (df["transaction_freq"] > 10).astype(int)
    df["risk_score"]     = (
        df["failed_attempts"] * 2 +
        df["is_night"]        * 1.5 +
        df["is_international"] * 1 +
        df["high_freq_flag"]  * 2
    )
    return df


# ══════════════════════════════════════════════════════════════
# SECTION 3 — MODEL TRAINING
# ══════════════════════════════════════════════════════════════

def train_models(df: pd.DataFrame):
    """Train Isolation Forest (unsupervised) + Random Forest (supervised)."""
    df = engineer_features(df)
    X  = df[ENGINEERED_COLS]
    y  = df["is_fraud"]

    scaler   = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    X_train, X_test, y_train, y_test = train_test_split(
        X_scaled, y, test_size=0.2, random_state=42, stratify=y
    )

    # Isolation Forest — unsupervised anomaly detection
    logger.info("Training Isolation Forest ...")
    iso_forest = IsolationForest(
        n_estimators=100, contamination=0.02, random_state=42, n_jobs=-1
    )
    iso_forest.fit(X_train)

    # Random Forest — supervised classifier
    logger.info("Training Random Forest ...")
    rf = RandomForestClassifier(
        n_estimators=200, max_depth=12, class_weight="balanced",
        random_state=42, n_jobs=-1
    )
    rf.fit(X_train, y_train)

    # Evaluation
    y_pred = rf.predict(X_test)
    y_prob = rf.predict_proba(X_test)[:, 1]

    logger.info("\n" + "=" * 50)
    logger.info("RANDOM FOREST EVALUATION")
    logger.info("=" * 50)
    logger.info("\n" + classification_report(y_test, y_pred, target_names=["Legit", "Fraud"]))
    logger.info(f"ROC-AUC Score : {roc_auc_score(y_test, y_prob):.4f}")

    cm = confusion_matrix(y_test, y_pred)
    logger.info(f"Confusion Matrix:\n{cm}")
    logger.info(f"  True Negatives  : {cm[0][0]}")
    logger.info(f"  False Positives : {cm[0][1]}")
    logger.info(f"  False Negatives : {cm[1][0]}")
    logger.info(f"  True Positives  : {cm[1][1]}")

    importances = pd.Series(rf.feature_importances_, index=ENGINEERED_COLS)
    logger.info("\nTop Feature Importances:")
    logger.info(importances.sort_values(ascending=False).to_string())

    # Save models
    joblib.dump(rf,         RF_MODEL_PATH)
    joblib.dump(iso_forest, IF_MODEL_PATH)
    joblib.dump(scaler,     SCALER_PATH)
    logger.info(f"\nModels saved to '{MODEL_DIR}/'")

    # Auto-generate all charts after training
    logger.info("\nGenerating performance charts ...")
    plot_class_distribution(y)
    plot_feature_distributions(df)
    plot_confusion_matrix(y_test, y_pred)
    plot_roc_curve(y_test, y_prob)
    plot_feature_importance(rf, ENGINEERED_COLS)

    return rf, iso_forest, scaler


# ══════════════════════════════════════════════════════════════
# SECTION 4 — REAL-TIME PREDICTION ENGINE
# ══════════════════════════════════════════════════════════════

class FraudDetector:
    """
    Real-time fraud detection engine.
    Loads trained models and predicts fraud probability for incoming transactions.
    """

    ALERT_THRESHOLD = 0.60   # combined score above which an alert is raised

    def __init__(self):
        if not os.path.exists(RF_MODEL_PATH):
            raise FileNotFoundError("Models not found. Run train_models() first.")
        self.rf        = joblib.load(RF_MODEL_PATH)
        self.iso       = joblib.load(IF_MODEL_PATH)
        self.scaler    = joblib.load(SCALER_PATH)
        self.alert_log = []
        logger.info("FraudDetector loaded and ready.")

    def predict(self, transaction: dict) -> dict:
        """
        Analyse a single transaction and return a risk verdict.

        Parameters
        ----------
        transaction : dict  — keys must match FEATURE_COLS

        Returns
        -------
        dict: {
            transaction_id, amount, fraud_probability, anomaly_score,
            combined_score, is_fraud_predicted, risk_level, alert, timestamp
        }
        """
        tx_id = transaction.get("transaction_id", f"TXN-{datetime.now().strftime('%H%M%S%f')}")

        row = pd.DataFrame([{k: transaction.get(k, 0) for k in FEATURE_COLS}])
        row = engineer_features(row)
        X   = self.scaler.transform(row[ENGINEERED_COLS])

        # Random Forest fraud probability
        fraud_prob = float(self.rf.predict_proba(X)[0][1])

        # Isolation Forest anomaly score (normalised 0-1)
        iso_raw       = float(self.iso.decision_function(X)[0])
        anomaly_score = float(np.clip(1 - (iso_raw + 0.5), 0, 1))

        # Weighted combined score
        combined = 0.7 * fraud_prob + 0.3 * anomaly_score
        is_fraud = combined >= self.ALERT_THRESHOLD

        if   combined >= 0.80: risk_level = "CRITICAL"
        elif combined >= 0.60: risk_level = "HIGH"
        elif combined >= 0.40: risk_level = "MEDIUM"
        else:                  risk_level = "LOW"

        result = {
            "transaction_id"    : tx_id,
            "amount"            : transaction.get("transaction_amount", 0),
            "fraud_probability" : round(fraud_prob, 4),
            "anomaly_score"     : round(anomaly_score, 4),
            "combined_score"    : round(combined, 4),
            "is_fraud_predicted": is_fraud,
            "risk_level"        : risk_level,
            "alert"             : is_fraud,
            "timestamp"         : datetime.now().isoformat(),
        }

        if is_fraud:
            logger.warning(
                f"FRAUD ALERT | {tx_id} | Rs.{result['amount']:,.2f} | "
                f"Risk={risk_level} | Score={combined:.4f}"
            )
            self.alert_log.append(result)
        else:
            logger.info(
                f"Legitimate  | {tx_id} | Rs.{result['amount']:,.2f} | "
                f"Risk={risk_level} | Score={combined:.4f}"
            )

        return result

    def batch_predict(self, transactions: list) -> pd.DataFrame:
        """Score a list of transaction dicts and return a results DataFrame."""
        return pd.DataFrame([self.predict(tx) for tx in transactions])

    def get_alert_summary(self) -> dict:
        """Return summary statistics for all alerts raised in this session."""
        total   = len(self.alert_log)
        amounts = [a["amount"] for a in self.alert_log]
        return {
            "total_alerts"        : total,
            "high_risk_alerts"    : sum(1 for a in self.alert_log if a["risk_level"] in ("HIGH", "CRITICAL")),
            "total_flagged_amount": sum(amounts),
            "avg_flagged_amount"  : round(sum(amounts) / total, 2) if total else 0,
        }


